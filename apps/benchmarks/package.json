{
  "name": "@mohi/benchmarks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "tsx src/bench.ts",
    "build": "tsup src/bench.ts --format esm --outDir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@mohi/diff": "workspace:*",
    "@mohi/diff-wasm": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
